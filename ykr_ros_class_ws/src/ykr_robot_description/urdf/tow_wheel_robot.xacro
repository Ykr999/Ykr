<?xml version="1.0"?>
<robot name="two_wheel_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <!-- 第1步：提取所有尺寸参数 -->
  <!-- 底盘参数 -->
  <xacro:property name="chassis_length" value="0.5"/>
  <xacro:property name="chassis_width" value="0.3"/>
  <xacro:property name="chassis_height" value="0.1"/>
  <xacro:property name="chassis_mass" value="5.0"/>

  <!-- 轮子参数 -->
  <xacro:property name="wheel_radius" value="0.1"/>
  <xacro:property name="wheel_length" value="0.05"/>
  <xacro:property name="wheel_separation" value="0.3"/>
  <xacro:property name="wheel_x_offset" value="0.18"/>
  <xacro:property name="wheel_mass" value="1.0"/>

  <!-- 激光雷达参数 -->
  <xacro:property name="laser_radius" value="0.05"/>
  <xacro:property name="laser_height" value="0.1"/>
  <xacro:property name="laser_x_offset" value="0.2"/>
  <xacro:property name="laser_z_offset" value="0.05"/>
  <xacro:property name="laser_mass" value="0.5"/>

  <!-- 第5步：编写底盘和base_footprint（必须放在宏调用之前，因为父link是base_link） -->
  <!-- 底盘 base_link -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${chassis_length}${chassis_width}${chassis_height}"/>
      </geometry>
      <material name="blue">
        <color rgba="0 0 1 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${chassis_length}${chassis_width}${chassis_height}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="${chassis_mass}"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
  </link>

  <!-- base_footprint 坐标系 -->
  <link name="base_footprint"/>
  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
  </joint>

  <!-- 第3步：定义轮子宏 -->
  <xacro:macro name="wheel" params="side sign">
    <link name="wheel_${side}_link">
      <visual>
        <origin xyz="0 0 0" rpy="1.5708 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_length}"/>
        </geometry>
        <material name="black">
          <color rgba="0 0 0 1"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="1.5708 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_length}"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="${wheel_mass}"/>
        <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
      </inertial>
    </link>

    <joint name="wheel_${side}_joint" type="continuous">
      <parent link="base_link"/>
      <child link="wheel_${side}_link"/>
      <origin xyz="${wheel_x_offset}${sign * wheel_separation/2} -0.05" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit effort="100" velocity="10"/>
    </joint>
  </xacro:macro>

  <!-- 第4步：定义激光雷达宏 -->
  <xacro:macro name="laser">
    <link name="laser_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${laser_radius}" length="${laser_height}"/>
        </geometry>
        <material name="red">
          <color rgba="1 0 0 1"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${laser_radius}" length="${laser_height}"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="${laser_mass}"/>
        <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
      </inertial>
    </link>

    <joint name="laser_joint" type="fixed">
      <parent link="base_link"/>
      <child link="laser_link"/>
      <origin xyz="${laser_x_offset} 0${chassis_height/2 + laser_z_offset}" rpy="0 0 0"/>
    </joint>
  </xacro:macro>

  <!-- 第3步：调用轮子宏两次 -->
  <xacro:wheel side="left" sign="1"/>
  <xacro:wheel side="right" sign="-1"/>

  <!-- 第4步：调用激光雷达宏 -->
  <xacro:laser/>
</robot>
